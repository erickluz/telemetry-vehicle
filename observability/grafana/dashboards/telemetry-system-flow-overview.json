{
  "id": null,
  "uid": "telemetry-system-flow-overview",
  "title": "Telemetry System Flow Overview",
  "tags": ["telemetry", "overview", "system-flow", "rabbitmq", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 6,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(up, job)",
        "refresh": 1,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "queue",
        "type": "custom",
        "query": "telemetry.events,telemetry.events.retry,telemetry.events.dlq,telemetry.alerts",
        "includeAll": true,
        "allValue": "telemetry\\.events|telemetry\\.events\\.retry|telemetry\\.events\\.dlq|telemetry\\.alerts",
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "A) System Health",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 2,
      "title": "Services UP",
      "description": "Total Prometheus targets currently reachable. A lower value means at least one service or RabbitMQ metrics target is down.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(up)", "legendFormat": "up"}],
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto"}
    },
    {
      "id": 3,
      "title": "Services DOWN",
      "description": "Targets reporting DOWN. Empty means all configured targets are reachable.",
      "type": "table",
      "gridPos": {"h": 5, "w": 8, "x": 4, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "up == 0", "legendFormat": "{{job}}"}]
    },
    {
      "id": 4,
      "title": "Total HTTP RPS",
      "description": "Aggregate request rate across all Spring Boot services.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 12, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count[1m]))", "legendFormat": "rps"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 5,
      "title": "Total HTTP 5xx RPS",
      "description": "Aggregate server error rate. Use the HTTP error panels below to identify the service.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 16, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{status=~\"5..\"}[1m]))", "legendFormat": "5xx"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 6,
      "title": "Average HTTP Latency",
      "description": "Global average HTTP latency across services.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 20, "y": 1},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_sum[1m])) / sum(rate(http_server_requests_seconds_count[1m]))", "legendFormat": "latency"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 7,
      "title": "B) Load Generator",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 8,
      "title": "Load Generator HTTP Requests",
      "description": "API traffic hitting telemetry-load-generator-service.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{job=\"telemetry-load-generator-service\"}[1m]))", "legendFormat": "rps"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 9,
      "title": "Load Generator Errors",
      "description": "4xx and 5xx responses from telemetry-load-generator-service.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{job=\"telemetry-load-generator-service\",status=~\"5..|4..\"}[1m]))", "legendFormat": "errors"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 10,
      "title": "Load Generator RPS by URI",
      "description": "Shows which load-generator endpoints are being used.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 7},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"telemetry-load-generator-service\"}[1m]))", "legendFormat": "{{uri}}"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 11,
      "title": "TODO - Custom metric required - Load Sent Events",
      "description": "Will show generated telemetry events when telemetry_load_events_sent_total is added.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 12, "x": 0, "y": 12},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(telemetry_load_events_sent_total[1m]))", "legendFormat": "events/s"}],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 12,
      "title": "C) Ingestion",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 17},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 13,
      "title": "Ingestion RPS",
      "description": "Request rate reaching the ingestion service. The repo job is vehicle-ingestion-service.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{job=~\"vehicle-ingestion-service|telemetry-ingestion-service\"}[1m])) or vector(0)", "legendFormat": "rps"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 14,
      "title": "Ingestion Errors",
      "description": "4xx and 5xx responses from the ingestion service.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rate(http_server_requests_seconds_count{job=~\"vehicle-ingestion-service|telemetry-ingestion-service\",status=~\"5..|4..\"}[1m])) or vector(0)", "legendFormat": "errors"}],
      "fieldConfig": {"defaults": {"unit": "reqps"}, "overrides": []}
    },
    {
      "id": 15,
      "title": "Ingestion Latency",
      "description": "Average latency for ingestion HTTP endpoints.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 18},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "(sum(rate(http_server_requests_seconds_sum{job=~\"vehicle-ingestion-service|telemetry-ingestion-service\"}[1m])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=~\"vehicle-ingestion-service|telemetry-ingestion-service\"}[1m])), 1)) or vector(0)", "legendFormat": "latency"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 16,
      "title": "Ingestion Target UP",
      "description": "Prometheus reachability for the ingestion service target.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 23},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "max(up{job=~\"vehicle-ingestion-service|telemetry-ingestion-service\"}) or vector(0)", "legendFormat": "up"}],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}, "overrides": []}
    },
    {
      "id": 17,
      "title": "Ingestion Scrape Samples",
      "description": "Number of samples scraped from the ingestion service. A zero value means the target is not being scraped successfully.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 23},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(scrape_samples_scraped{job=~\"vehicle-ingestion-service|telemetry-ingestion-service\"}) or vector(0)", "legendFormat": "samples"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 18,
      "title": "D) RabbitMQ Flow",
      "type": "row",
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31},
      "collapsed": false,
      "panels": []
    },
    {
      "id": 19,
      "title": "RabbitMQ Broker UP",
      "description": "Prometheus reachability for RabbitMQ aggregate and detailed queue scrape targets.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 0, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "up{job=~\"rabbitmq|rabbitmq-detailed-queues\"}", "legendFormat": "{{job}}"}
      ],
      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "DOWN", "color": "red"}, "1": {"text": "UP", "color": "green"}}}]}, "overrides": []}
    },
    {
      "id": 20,
      "title": "RabbitMQ Connections",
      "description": "Current broker-level client connections.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 4, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rabbitmq_connections{job=\"rabbitmq\"}) or vector(0)", "legendFormat": "connections"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 21,
      "title": "RabbitMQ Channels",
      "description": "Current broker-level channels.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 8, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rabbitmq_channels{job=\"rabbitmq\"}) or vector(0)", "legendFormat": "channels"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 22,
      "title": "RabbitMQ Consumers",
      "description": "Current broker-level consumers.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 12, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rabbitmq_consumers{job=\"rabbitmq\"}) or vector(0)", "legendFormat": "consumers"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 23,
      "title": "RabbitMQ Queues",
      "description": "Current number of queues in the broker.",
      "type": "stat",
      "gridPos": {"h": 5, "w": 4, "x": 16, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rabbitmq_queues{job=\"rabbitmq\"}) or vector(0)", "legendFormat": "queues"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 24,
      "title": "RabbitMQ Memory Usage %",
      "description": "Broker memory pressure. High values increase operational risk.",
      "type": "gauge",
      "gridPos": {"h": 5, "w": 4, "x": 20, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "(100 * sum(rabbitmq_process_resident_memory_bytes{job=\"rabbitmq\"}) / clamp_min(sum(rabbitmq_resident_memory_limit_bytes{job=\"rabbitmq\"}), 1)) or (100 * sum(rabbitmq_node_mem_used{job=\"rabbitmq\"}) / clamp_min(sum(rabbitmq_node_mem_limit{job=\"rabbitmq\"}), 1)) or vector(0)", "legendFormat": "memory %"}],
      "fieldConfig": {"defaults": {"unit": "percent", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 70}, {"color": "red", "value": 85}]}}, "overrides": []}
    },
    {
      "id": 100,
      "title": "Ready Messages by Queue",
      "description": "Ready messages are waiting to be consumed.",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 37},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (queue) (rabbitmq_detailed_queue_messages_ready{queue=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"}) or sum by (queue) (rabbitmq_queue_messages_ready{queue=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"}) or sum by (name) (rabbitmq_detailed_queue_messages_ready{name=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"})", "legendFormat": "{{queue}}{{name}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 101,
      "title": "Unacked Messages by Queue",
      "description": "Unacked messages were delivered to consumers but have not been ACKed yet.",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 37},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (queue) (rabbitmq_detailed_queue_messages_unacked{queue=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"}) or sum by (queue) (rabbitmq_queue_messages_unacked{queue=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"}) or sum by (name) (rabbitmq_detailed_queue_messages_unacked{name=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"})", "legendFormat": "{{queue}}{{name}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 102,
      "title": "Consumers by Queue",
      "description": "A queue with 0 consumers can indicate a stopped consumer service or unused binding.",
      "type": "bargauge",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 37},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (queue) (rabbitmq_queue_consumers{queue=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"}) or sum by (name) (rabbitmq_detailed_queue_consumers{name=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"}) or label_replace(sum(rabbitmq_consumers{job=\"rabbitmq\"}), \"queue\", \"all-queues\", \"job\", \".*\")", "legendFormat": "{{queue}}{{name}}"}],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []}
    },
    {
      "id": 103,
      "title": "Queue Operational Status",
      "description": "Per-queue ready and unacked message counts. Consumers are shown as aggregate if per-queue consumer metrics are unavailable.",
      "type": "table",
      "gridPos": {"h": 7, "w": 24, "x": 0, "y": 45},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (queue) (rabbitmq_detailed_queue_messages_ready{queue=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"}) or sum by (name) (rabbitmq_detailed_queue_messages_ready{name=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"})", "legendFormat": "ready {{queue}}{{name}}"},
        {"expr": "sum by (queue) (rabbitmq_detailed_queue_messages_unacked{queue=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"}) or sum by (name) (rabbitmq_detailed_queue_messages_unacked{name=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"})", "legendFormat": "unacked {{queue}}{{name}}"},
        {"expr": "sum by (queue) (rabbitmq_queue_consumers{queue=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"}) or sum by (name) (rabbitmq_detailed_queue_consumers{name=~\"telemetry\\\\.events|telemetry\\\\.events\\\\.retry|telemetry\\\\.events\\\\.dlq|telemetry\\\\.alerts|vehicle\\\\.dashboard\\\\.alerts\"})", "legendFormat": "consumers {{queue}}{{name}}"}
      ]
    },
    {
      "id": 104,
      "title": "Broker Message Rates",
      "description": "Publish vs delivery rate. If incoming/routed is greater than delivered for long periods, backlog tends to grow.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 0, "y": 52},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum(rate(rabbitmq_global_messages_received_total{job=\"rabbitmq\"}[1m])) or vector(0)", "legendFormat": "received"},
        {"expr": "sum(rate(rabbitmq_global_messages_routed_total{job=\"rabbitmq\"}[1m])) or vector(0)", "legendFormat": "routed"},
        {"expr": "sum(rate(rabbitmq_global_messages_delivered_total{job=\"rabbitmq\"}[1m])) or vector(0)", "legendFormat": "delivered"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 105,
      "title": "Queue Publish Rate by Queue",
      "description": "Per-queue publish rate when available, with aggregate broker fallback.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 8, "y": 52},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (queue) (rate(rabbitmq_detailed_queue_messages_published_total{queue=~\"telemetry.*|vehicle.*\"}[1m])) or sum by (name) (rate(rabbitmq_detailed_queue_messages_published_total{name=~\"telemetry.*|vehicle.*\"}[1m])) or sum by (queue) (rate(rabbitmq_queue_messages_published_total{queue=~\"telemetry.*|vehicle.*\"}[1m])) or label_replace(sum(rate(rabbitmq_queue_messages_published_total{job=\"rabbitmq\"}[1m])), \"queue\", \"all-queues\", \"job\", \".*\") or vector(0)", "legendFormat": "{{queue}}{{name}}"}],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 106,
      "title": "Queue Delivery / Ack Rate by Queue",
      "description": "Delivery and ACK rate by queue when available, with broker delivery fallback.",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 52},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {"expr": "sum by (queue) (rate(rabbitmq_detailed_queue_messages_delivered_total{queue=~\"telemetry.*|vehicle.*\"}[1m])) or sum by (name) (rate(rabbitmq_detailed_queue_messages_delivered_total{name=~\"telemetry.*|vehicle.*\"}[1m])) or label_replace(sum(rate(rabbitmq_global_messages_delivered_total{job=\"rabbitmq\"}[1m])), \"queue\", \"all-queues-delivered\", \"job\", \".*\") or vector(0)", "legendFormat": "delivered {{queue}}{{name}}"},
        {"expr": "sum by (queue) (rate(rabbitmq_detailed_queue_messages_acknowledged_total{queue=~\"telemetry.*|vehicle.*\"}[1m])) or sum by (name) (rate(rabbitmq_detailed_queue_messages_acknowledged_total{name=~\"telemetry.*|vehicle.*\"}[1m])) or vector(0)", "legendFormat": "acked {{queue}}{{name}}"}
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 107,
      "title": "Redelivery Rate",
      "description": "Redeliveries indicate messages being retried after failed or timed-out consumption.",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 60},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (queue) (rate(rabbitmq_detailed_queue_messages_redelivered_total{queue=~\"telemetry.*|vehicle.*\"}[1m])) or sum by (name) (rate(rabbitmq_detailed_queue_messages_redelivered_total{name=~\"telemetry.*|vehicle.*\"}[1m])) or sum(rate(rabbitmq_global_messages_redelivered_total{job=\"rabbitmq\"}[1m])) or vector(0)", "legendFormat": "{{queue}}{{name}}redelivered"}],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []}
    },
    {
      "id": 108,
      "title": "RabbitMQ Memory Used",
      "description": "Broker resident memory in bytes.",
      "type": "timeseries",
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 60},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rabbitmq_process_resident_memory_bytes{job=\"rabbitmq\"}) or sum(rabbitmq_node_mem_used{job=\"rabbitmq\"}) or vector(0)", "legendFormat": "memory"}],
      "fieldConfig": {"defaults": {"unit": "bytes"}, "overrides": []}
    },
    {
      "id": 109,
      "title": "Main Queue Depth",
      "description": "Ready messages waiting in telemetry.events.",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 0, "y": 67},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rabbitmq_detailed_queue_messages_ready{queue=\"telemetry.events\"}) or sum(rabbitmq_queue_messages_ready{queue=\"telemetry.events\"}) or sum(rabbitmq_detailed_queue_messages_ready{name=\"telemetry.events\"}) or vector(0)", "legendFormat": "main"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 100}, {"color": "red", "value": 1000}]}}, "overrides": []}
    },
    {
      "id": 110,
      "title": "Retry Queue Depth",
      "description": "Retry depth: messages waiting for another processing attempt.",
      "type": "stat",
      "gridPos": {"h": 6, "w": 4, "x": 4, "y": 67},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum(rabbitmq_detailed_queue_messages_ready{queue=\"telemetry.events.retry\"}) or sum(rabbitmq_queue_messages_ready{queue=\"telemetry.events.retry\"}) or sum(rabbitmq_detailed_queue_messages_ready{name=\"telemetry.events.retry\"}) or vector(0)", "legendFormat": "retry"}],
      "fieldConfig": {"defaults": {"unit": "short", "thresholds": {"mode": "absolute", "steps": [{"color": "green"}, {"color": "yellow", "value": 1}, {"color": "red", "value": 50}]}}, "overrides": []}
    },
    {
      "id": 111,
