{
  "id": null,
  "uid": "http-overview",
  "title": "HTTP Overview",
  "tags": ["telemetry", "http", "spring-boot"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "HTTP requests per second by application",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (application) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{application}}"}]
    },
    {
      "id": 2,
      "title": "HTTP error rate by application",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (application) (rate(http_server_requests_seconds_count{status=~\"4..|5..\"}[1m]))", "legendFormat": "{{application}}"}]
    },
    {
      "id": 3,
      "title": "Average HTTP latency",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "sum by (application) (rate(http_server_requests_seconds_sum[1m])) / sum by (application) (rate(http_server_requests_seconds_count[1m]))", "legendFormat": "{{application}}"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 4,
      "title": "HTTP latency p95",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "histogram_quantile(0.95, sum by (application, le) (rate(http_server_requests_seconds_bucket[5m])))", "legendFormat": "{{application}} p95"}],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []}
    },
    {
      "id": 5,
      "title": "Top URIs by request volume",
      "type": "barchart",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [{"expr": "topk(10, sum by (application, uri) (rate(http_server_requests_seconds_count{uri!=\"UNKNOWN\"}[5m])))", "legendFormat": "{{application}} {{uri}}"}]
    }
  ]
}
